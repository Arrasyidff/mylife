generator client {
  provider     = "prisma-client-js"
  output       = "../generated/prisma"
  moduleFormat = "commonjs"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum AksesLevel {
  SUPER_ADMIN
  ADMIN
  VIEWER
}

enum Status {
  ACTIVE
  INACTIVE
}

enum AccountType {
  TABUNGAN
  EWALLET
  TUNAI
  INVESTASI
  KARTU_KREDIT
}

enum TransactionType {
  EXPENSE
  INCOME
  TRANSFER
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  YEARLY
}

enum FamilyMember {
  SUAMI
  ISTRI
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  full_name    String
  username     String     @unique
  email        String     @unique
  password     String
  access_level AksesLevel @default(VIEWER)
  position     String?    @db.VarChar(100)
  phone_number String?    @db.VarChar(20)
  address      String?    @db.Text
  status       Status     @default(ACTIVE)
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt

  activity_logs ActivityLog[]
  accounts      Account[]
  budgets       Budget[]

  @@map("users")
}

model ActivityLog {
  id          String   @id @default(uuid())
  user_id     String
  user_name   String
  action      String
  module      String
  description String?  @db.Text
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@map("activity_logs")
}

model Account {
  id             String      @id @default(uuid())
  user_id        String
  name           String      @db.VarChar(100)
  subtitle       String?     @db.VarChar(200)
  balance        Decimal     @default(0) @db.Decimal(15, 2)
  color          String      @db.VarChar(7)
  glyph          String      @db.VarChar(10)
  type           AccountType
  account_number String?     @db.VarChar(50)
  hidden         Boolean     @default(false)
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  user         User          @relation(fields: [user_id], references: [id])
  transactions Transaction[] @relation("FromAccount")
  transfers_in Transaction[] @relation("ToAccount")

  @@map("accounts")
}

model Transaction {
  id             Int             @id @default(autoincrement())
  recorder       FamilyMember
  category       String          @db.VarChar(50)
  merchant       String          @db.VarChar(200)
  account_id     String
  to_account_id  String?
  amount         Decimal         @db.Decimal(15, 2)
  date           DateTime
  type           TransactionType
  note           String?         @db.Text
  transfer_group String?         @db.VarChar(36)
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt

  account    Account  @relation("FromAccount", fields: [account_id], references: [id])
  to_account Account? @relation("ToAccount", fields: [to_account_id], references: [id])

  @@index([account_id])
  @@index([date])
  @@index([type])
  @@index([transfer_group])
  @@map("transactions")
}

model Budget {
  id         String       @id @default(uuid())
  user_id    String
  name       String       @db.VarChar(100)
  category   String       @db.VarChar(50)
  total      Decimal      @db.Decimal(15, 2)
  period     BudgetPeriod @default(MONTHLY)
  carry_over Boolean      @default(false)
  start_date DateTime
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@map("budgets")
}
